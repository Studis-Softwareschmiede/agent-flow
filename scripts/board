#!/usr/bin/env bash
# scripts/board — Board-Abstraktion (board-cli-Spec, AC1–AC11)
#
# Verben (implementiert): feature add, story add, set, show, list, next,
#                         rollup (AC7), lint (AC8, delegiert an board-lint.sh),
#                         ready (AC12, F-008 „Autonome Board-Abarbeitung"),
#                         export-github (AC11, Stub/Registrierung — #129),
#                         area list/merge (board-area-ops AC1/AC2/AC5, S-036),
#                         area split (board-area-ops AC4/AC5, S-037),
#                         archive-done-stories (board-area-ops AC3/AC5, S-038)
# Single-Writer-Erzwingung: AC9
#
# Requires: bash >= 4.0, python3 mit PyYAML
#
# Ausgabe:
#   feature add  → F-### (stdout)
#   story   add  → S-### (stdout)
#   set          → <id> (stdout)
#   show         → JSON (stdout)
#   list         → JSON-Array (stdout)
#   next         → JSON (id, spec, implements, parent, priority, labels, …) | leer (Exit 0)
#   Fehler       → Meldung (stderr), Exit ≠ 0

set -euo pipefail

# ---------------------------------------------------------------------------
# Hilfsfunktionen
# ---------------------------------------------------------------------------

die() {
  echo "FEHLER: $*" >&2
  exit 1
}

usage() {
  cat >&2 <<'EOF'
Verwendung:
  board feature add --title <t> --goal <g> --priority <P0-P3> [--spec <f>] [--labels <l1,l2>] [--depends <F-###,…>]
  board story   add --parent <F-###> --title <t> --spec <f> --implements <AC1,AC2> [--priority <P0-P3>] [--depends <S-###,…>] [--labels <l1,l2>]
  board set <id> <feld> <wert> [--reason <text>]
  board show <id>
  board list [--type feature|story] [--status <status>] [--parent <F-###>]
  board next
  board rollup <F-###|--all>
  board lint [<board-dir>]
  board ready [--quiet]
  board export-github
  board area list
  board area merge <a> <b> <ziel>
  board area split <a> <a1> <a2>
  board archive-done-stories
EOF
  exit 1
}

# ISO-8601-UTC-Zeitstempel (jetzt)
now_ts() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

# Slug aus Titel: Kleinbuchstaben, Leerzeichen/Sonderzeichen → Bindestrich,
# mehrfache/führende/abschließende Bindestriche kollabieren.
slugify() {
  local title="$1"
  # Python für robuste Unicode-Behandlung
  python3 -c "
import re, sys
t = sys.argv[1].lower()
t = re.sub(r'[^a-z0-9]+', '-', t)
t = t.strip('-')
print(t[:60] if t else 'item')
" "$title"
}

# Nullsicheres YAML-Feld lesen: gibt leeren String für null zurück
yaml_field() {
  local file="$1" field="$2"
  python3 - "$file" "$field" <<'PYEOF'
import sys, yaml
file, field = sys.argv[1], sys.argv[2]
with open(file) as f:
    data = yaml.safe_load(f) or {}
val = data.get(field)
print("" if val is None else str(val))
PYEOF
}

# Board-Verzeichnis bestimmen (Standard: board/ relativ zum Repo-Root)
# Das Skript wird typischerweise aus dem Repo-Root aufgerufen.
BOARD_DIR="${BOARD_DIR:-board}"
BOARD_YAML="${BOARD_DIR}/board.yaml"
FEATURES_DIR="${BOARD_DIR}/features"
STORIES_DIR="${BOARD_DIR}/stories"

# board.yaml existieren-Prüfung (für schreibende Verben)
require_board() {
  if [[ ! -f "$BOARD_YAML" ]]; then
    die "Board nicht initialisiert — ${BOARD_YAML} fehlt"
  fi
}

# Alle Feature-Dateien einsammeln (sortiert)
all_features() {
  find "$FEATURES_DIR" -name "F-*.yaml" -print 2>/dev/null | sort
}

# Alle Story-Dateien einsammeln (sortiert), archive/ ignorieren
all_stories() {
  find "$STORIES_DIR" -name "S-*.yaml" -not -path "*/archive/*" -print 2>/dev/null | sort
}

# YAML-Datei als JSON ausgeben (alle Felder, null-sicher)
yaml_to_json() {
  local file="$1"
  python3 - "$file" <<'PYEOF'
import sys, yaml, json, datetime

def normalize(val):
    """YAML-Typen → JSON-serialisierbar."""
    if isinstance(val, datetime.datetime):
        if val.tzinfo is not None:
            import datetime as dt
            val = val.astimezone(dt.timezone.utc)
        return val.strftime("%Y-%m-%dT%H:%M:%SZ")
    if isinstance(val, datetime.date):
        return val.isoformat()
    if isinstance(val, dict):
        return {k: normalize(v) for k, v in val.items()}
    if isinstance(val, list):
        return [normalize(i) for i in val]
    return val

file = sys.argv[1]
with open(file) as f:
    data = yaml.safe_load(f) or {}
print(json.dumps(normalize(data), ensure_ascii=False))
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: feature add
#
# Atomarität (AC10 / coder/L14):
#   1. Python liest board.yaml, berechnet neue ID, schreibt BEIDE tmp-Dateien
#      (item-tmp + board-tmp) in einem einzigen Python-Lauf.
#   2. trap registriert sofort nach dem mktemp-Paar — räumt BEIDE tmp-Dateien
#      auf, falls ein späterer Schritt (python, mv) fehlschlägt.
#   3. Erst nach erfolgreichem mv item-tmp→outfile wird board-tmp→board.yaml
#      ge-mv't; danach wird der Trap aufgehoben.
#   → Kein Halbzustand: board.yaml-Zähler ist nie erhöht ohne zugehörige Datei.
# ---------------------------------------------------------------------------
cmd_feature_add() {
  local title="" goal="" priority="" spec="" labels="" depends=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)     shift; title="$1"    ;;
      --goal)      shift; goal="$1"     ;;
      --priority)  shift; priority="$1" ;;
      --spec)      shift; spec="$1"     ;;
      --labels)    shift; labels="$1"   ;;
      --depends)   shift; depends="$1"  ;;
      *) die "feature add: unbekannte Option '$1'" ;;
    esac
    shift
  done

  [[ -n "$title" ]]    || die "feature add: --title ist Pflicht"
  [[ -n "$goal" ]]     || die "feature add: --goal ist Pflicht"
  [[ -n "$priority" ]] || die "feature add: --priority ist Pflicht"

  # Enum-Prüfung
  case "$priority" in
    P0|P1|P2|P3) ;;
    *) die "feature add: --priority muss P0|P1|P2|P3 sein, war '$priority'" ;;
  esac

  require_board

  # Slug + Dateiname
  local slug
  slug="$(slugify "$title")"

  local ts
  ts="$(now_ts)"

  # Verzeichnis sicherstellen
  mkdir -p "$FEATURES_DIR"

  local features_abs board_abs
  features_abs="$(cd "$FEATURES_DIR" && pwd)"
  board_abs="$(cd "$(dirname "$BOARD_YAML")" && pwd)"

  # Temp-Dateien anlegen (I2: sofort trap registrieren)
  local tmp_item tmp_board
  tmp_item="$(mktemp "${features_abs}/feature.XXXXXX")"
  tmp_board="$(mktemp "${board_abs}/board.yaml.XXXXXX")"

  # Trap: beide tmp-Dateien aufräumen bei Fehler (I2)
  # Doppelte Anführungszeichen → Variablen expandieren bei trap-Definition
  # → korrekte Werte auch nach Funktionsrückkehr (verhindert "unbound var")
  trap "rm -f \"$tmp_item\" \"$tmp_board\"" EXIT

  # Python: liest board.yaml, inkrementiert Zähler, schreibt BEIDE tmp-Dateien
  # (I1: board.yaml wird erst am Ende ge-mv't → kein Halbzustand)
  local new_id
  new_id=$(python3 - "$BOARD_YAML" "next_feature_id" "F" \
              "$tmp_board" "$tmp_item" "$title" "$goal" "$priority" \
              "$spec" "$labels" "$depends" "$ts" <<'PYEOF'
import sys, yaml

board_yaml   = sys.argv[1]
counter_key  = sys.argv[2]
prefix       = sys.argv[3]
tmp_board    = sys.argv[4]
tmp_item     = sys.argv[5]
title        = sys.argv[6]
goal         = sys.argv[7]
priority     = sys.argv[8]
spec         = sys.argv[9] or None
labels_s     = sys.argv[10]
depends_s    = sys.argv[11]
ts           = sys.argv[12]

# --- board.yaml lesen und Zähler erhöhen ---
with open(board_yaml) as f:
    board_data = yaml.safe_load(f) or {}

current = board_data.get(counter_key)
if not isinstance(current, int) or current < 1:
    sys.exit(f"FEHLER: {counter_key} in {board_yaml} kein gültiger int >= 1")

new_id_num = current
new_id     = f"{prefix}-{new_id_num:03d}"
board_data[counter_key] = current + 1

# --- Item-YAML zusammenbauen ---
labels  = [l.strip() for l in labels_s.split(",") if l.strip()] if labels_s else None
depends = [d.strip() for d in depends_s.split(",") if d.strip()] if depends_s else None

item_data = {
    "id":       new_id,
    "title":    title,
    "goal":     goal,
    "status":   "Backlog",
    "priority": priority,
    "spec":     spec,
    "definition_of_done": None,
    "labels":   labels,
    "depends":  depends,
    "owner":    None,
    "stories":  None,
    "progress": None,
    "created_at":  ts,
    "updated_at":  ts,
}

# --- Beide tmp-Dateien schreiben ---
with open(tmp_board, "w") as f:
    yaml.dump(board_data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)

with open(tmp_item, "w") as f:
    yaml.dump(item_data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)

print(new_id)
PYEOF
)

  # Zieldatei-Pfad (jetzt bekannt, da new_id ermittelt)
  local outfile="${FEATURES_DIR}/${new_id}-${slug}.yaml"

  # mv item-tmp → Zieldatei (atomar: rename(2))
  mv "$tmp_item" "$outfile"
  # mv board-tmp → board.yaml (Zähler erst jetzt sichtbar — I1 erfüllt)
  mv "$tmp_board" "$BOARD_YAML"

  # Trap aufheben (Erfolg — keine tmp-Dateien mehr vorhanden)
  trap - EXIT

  echo "$new_id"
}

# ---------------------------------------------------------------------------
# Verb: story add
#
# Atomarität: analog zu cmd_feature_add (siehe dort).
# ---------------------------------------------------------------------------
cmd_story_add() {
  local parent="" title="" spec="" implements="" priority="P2" depends="" labels=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --parent)     shift; parent="$1"     ;;
      --title)      shift; title="$1"      ;;
      --spec)       shift; spec="$1"       ;;
      --implements) shift; implements="$1" ;;
      --priority)   shift; priority="$1"   ;;
      --depends)    shift; depends="$1"    ;;
      --labels)     shift; labels="$1"     ;;
      *) die "story add: unbekannte Option '$1'" ;;
    esac
    shift
  done

  [[ -n "$parent" ]]     || die "story add: --parent ist Pflicht"
  [[ -n "$title" ]]      || die "story add: --title ist Pflicht"
  [[ -n "$spec" ]]       || die "story add: --spec ist Pflicht"
  [[ -n "$implements" ]] || die "story add: --implements ist Pflicht"

  # Enum-Prüfung priority
  case "$priority" in
    P0|P1|P2|P3) ;;
    *) die "story add: --priority muss P0|P1|P2|P3 sein, war '$priority'" ;;
  esac

  # Parent-Format
  [[ "$parent" =~ ^F-[0-9]{3,}$ ]] || die "story add: --parent muss F-### sein, war '$parent'"

  require_board

  # Parent-Existenzprüfung (AC2: unbekanntes Parent → kein Schreiben, Exit ≠ 0)
  local parent_file_found=0
  if [[ -d "$FEATURES_DIR" ]]; then
    while IFS= read -r -d '' f; do
      local fid_in_file
      fid_in_file="$(yaml_field "$f" id)"
      if [[ "$fid_in_file" == "$parent" ]]; then
        parent_file_found=1
        break
      fi
    done < <(find "$FEATURES_DIR" -name "F-*.yaml" -print0 2>/dev/null)
  fi
  if [[ $parent_file_found -eq 0 ]]; then
    die "story add: Parent '${parent}' existiert nicht — kein Schreiben"
  fi

  # Slug
  local slug
  slug="$(slugify "$title")"

  local ts
  ts="$(now_ts)"

  mkdir -p "$STORIES_DIR"

  local stories_abs board_abs
  stories_abs="$(cd "$STORIES_DIR" && pwd)"
  board_abs="$(cd "$(dirname "$BOARD_YAML")" && pwd)"

  # Temp-Dateien anlegen (I2: sofort trap registrieren)
  local tmp_item tmp_board
  tmp_item="$(mktemp "${stories_abs}/story.XXXXXX")"
  tmp_board="$(mktemp "${board_abs}/board.yaml.XXXXXX")"

  # Trap: beide tmp-Dateien aufräumen bei Fehler (I2)
  trap "rm -f \"$tmp_item\" \"$tmp_board\"" EXIT

  # Python: liest board.yaml, inkrementiert Zähler, schreibt BEIDE tmp-Dateien
  local new_id
  new_id=$(python3 - "$BOARD_YAML" "next_story_id" "S" \
              "$tmp_board" "$tmp_item" "$parent" "$title" "$priority" \
              "$spec" "$implements" "$depends" "$labels" "$ts" <<'PYEOF'
import sys, yaml

board_yaml   = sys.argv[1]
counter_key  = sys.argv[2]
prefix       = sys.argv[3]
tmp_board    = sys.argv[4]
tmp_item     = sys.argv[5]
parent       = sys.argv[6]
title        = sys.argv[7]
priority     = sys.argv[8]
spec         = sys.argv[9]
impl_s       = sys.argv[10]
depends_s    = sys.argv[11]
labels_s     = sys.argv[12]
ts           = sys.argv[13]

# --- board.yaml lesen und Zähler erhöhen ---
with open(board_yaml) as f:
    board_data = yaml.safe_load(f) or {}

current = board_data.get(counter_key)
if not isinstance(current, int) or current < 1:
    sys.exit(f"FEHLER: {counter_key} in {board_yaml} kein gültiger int >= 1")

new_id_num = current
new_id     = f"{prefix}-{new_id_num:03d}"
board_data[counter_key] = current + 1

# --- Item-YAML zusammenbauen ---
implements = [a.strip() for a in impl_s.split(",") if a.strip()]
depends    = [d.strip() for d in depends_s.split(",") if d.strip()] if depends_s else None
labels     = [l.strip() for l in labels_s.split(",") if l.strip()] if labels_s else None

item_data = {
    "id":            new_id,
    "parent":        parent,
    "title":         title,
    "status":        "To Do",
    "priority":      priority,
    "spec":          spec,
    "implements":    implements,
    "depends":       depends,
    "labels":        labels,
    "size_est":      None,
    "dispo_est":     None,
    "dispo_act":     None,
    "dispo_forecast": None,
    "estimate_note": None,
    "confidence":    None,
    "tok_est":       None,
    "branch":        None,
    "pr":            None,
    "blocked_reason": None,
    "created_at":    ts,
    "updated_at":    ts,
    "done_at":       None,
}

# --- Beide tmp-Dateien schreiben ---
with open(tmp_board, "w") as f:
    yaml.dump(board_data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)

with open(tmp_item, "w") as f:
    yaml.dump(item_data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)

print(new_id)
PYEOF
)

  # Zieldatei-Pfad
  local outfile="${STORIES_DIR}/${new_id}-${slug}.yaml"

  # mv item-tmp → Zieldatei (atomar)
  mv "$tmp_item" "$outfile"
  # mv board-tmp → board.yaml (Zähler erst jetzt sichtbar — I1 erfüllt)
  mv "$tmp_board" "$BOARD_YAML"

  # Trap aufheben (Erfolg)
  trap - EXIT

  echo "$new_id"
}

# ---------------------------------------------------------------------------
# Hilfsfunktion: Datei eines Items finden (Feature oder Story)
# Gibt Pfad aus, leerer String wenn nicht gefunden.
# ---------------------------------------------------------------------------
find_item_file() {
  local id="$1"
  local file=""

  if [[ "$id" =~ ^F-[0-9]{3,}$ ]]; then
    if [[ -d "$FEATURES_DIR" ]]; then
      while IFS= read -r -d '' f; do
        local fid
        fid="$(yaml_field "$f" id)"
        if [[ "$fid" == "$id" ]]; then
          file="$f"
          break
        fi
      done < <(find "$FEATURES_DIR" -name "F-*.yaml" -print0 2>/dev/null)
    fi
  elif [[ "$id" =~ ^S-[0-9]{3,}$ ]]; then
    if [[ -d "$STORIES_DIR" ]]; then
      while IFS= read -r -d '' f; do
        local sid
        sid="$(yaml_field "$f" id)"
        if [[ "$sid" == "$id" ]]; then
          file="$f"
          break
        fi
      done < <(find "$STORIES_DIR" -name "S-*.yaml" -print0 2>/dev/null)
    fi
  fi

  echo "$file"
}

# ---------------------------------------------------------------------------
# Verb: set
# ---------------------------------------------------------------------------
cmd_set() {
  local id="" feld="" wert="" reason=""

  [[ $# -ge 3 ]] || die "set: Verwendung: board set <id> <feld> <wert> [--reason <text>]"

  id="$1"; shift
  feld="$1"; shift
  wert="$1"; shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) shift; reason="$1" ;;
      *) die "set: unbekannte Option '$1'" ;;
    esac
    shift
  done

  [[ -n "$id" ]]   || die "set: ID fehlt"
  [[ -n "$feld" ]] || die "set: Feld fehlt"

  # S4 — leerer Wert abweisen (außer "null" ist für null-bare Felder erlaubt)
  if [[ -z "$wert" ]]; then
    die "set: leerer Wert nicht erlaubt (nutze 'null' um ein Feld zu leeren)"
  fi

  # Abgeleitete Felder dürfen nicht via set gesetzt werden
  case "$feld" in
    stories|progress) die "set: Feld '$feld' ist abgeleitet und nur über 'board rollup' pflegbar" ;;
  esac

  # AC9 / V9 — Single-Writer-Erzwingung für Story-Status
  # Nur der /flow-Kontext darf `board set <story-id> status …` aufrufen.
  # Marker: Umgebungsvariable BOARD_WRITER=flow (muss von /flow gesetzt werden).
  # Nicht-Status-Felder und Feature-Status sind für alle Aufrufer erlaubt.
  if [[ "$id" =~ ^S-[0-9]{3,}$ && "$feld" == "status" ]]; then
    if [[ "${BOARD_WRITER:-}" != "flow" ]]; then
      die "set: nur /flow darf Story-Status setzen (BOARD_WRITER=flow fehlt)"
    fi
  fi

  # S1 — Enum-Guard für bekannte Enum-Felder (CLI-Layer-Abweisung)
  case "$feld" in
    status)
      if [[ "$id" =~ ^F-[0-9]{3,}$ ]]; then
        case "$wert" in
          Backlog|Planned|Active|Done|Archived) ;;
          *) die "set: status muss Backlog|Planned|Active|Done|Archived sein für Features, war '$wert'" ;;
        esac
      elif [[ "$id" =~ ^S-[0-9]{3,}$ ]]; then
        case "$wert" in
          "To Do"|"In Progress"|Blocked|"In Review"|Done|Verworfen) ;;
          *) die "set: status muss 'To Do'|'In Progress'|Blocked|'In Review'|Done|Verworfen sein für Stories, war '$wert'" ;;
        esac
      fi
      ;;
    priority)
      case "$wert" in
        P0|P1|P2|P3) ;;
        *) die "set: priority muss P0|P1|P2|P3 sein, war '$wert'" ;;
      esac
      ;;
  esac

  require_board

  local item_file
  item_file="$(find_item_file "$id")"
  [[ -n "$item_file" ]] || die "set: ID '${id}' nicht gefunden"

  # Sonderfall: status=Blocked erfordert --reason
  if [[ "$feld" == "status" && "$wert" == "Blocked" ]]; then
    [[ -n "$reason" ]] || die "set: status=Blocked erfordert --reason"
  fi

  local ts
  ts="$(now_ts)"

  # Atomar: temp in gleichem Verzeichnis
  local dir_abs
  dir_abs="$(cd "$(dirname "$item_file")" && pwd)"
  local tmp_file
  tmp_file="$(mktemp "${dir_abs}/$(basename "$item_file").XXXXXX")"

  # Cleanup-Trap: bei Fehler temp aufräumen (I2)
  # Doppelte Anführungszeichen expandieren $tmp_file sofort → sicher bei Funktionsende
  trap "rm -f \"$tmp_file\"" EXIT

  python3 - "$item_file" "$tmp_file" "$feld" "$wert" "$reason" "$ts" <<'PYEOF'
import sys, yaml, datetime

item_file = sys.argv[1]
tmp_out   = sys.argv[2]
feld      = sys.argv[3]
wert      = sys.argv[4]
reason    = sys.argv[5]
ts        = sys.argv[6]

def normalize(val):
    """YAML datetime → ISO-8601-String."""
    if isinstance(val, datetime.datetime):
        if val.tzinfo is not None:
            import datetime as dt
            val = val.astimezone(dt.timezone.utc)
        return val.strftime("%Y-%m-%dT%H:%M:%SZ")
    if isinstance(val, datetime.date):
        return val.isoformat() + "T00:00:00Z"
    if isinstance(val, dict):
        return {k: normalize(v) for k, v in val.items()}
    if isinstance(val, list):
        return [normalize(i) for i in val]
    return val

with open(item_file) as f:
    data = yaml.safe_load(f) or {}

# Wert normalisieren (Strings wie "null" → Python-None)
parsed_wert = wert if wert.lower() != "null" else None

# Feld setzen
data[feld] = parsed_wert

# Sonderfall: blocked_reason bei status=Blocked
if feld == "status" and wert == "Blocked" and reason:
    data["blocked_reason"] = reason

# Sonderfall: done_at bei status=Done
if feld == "status" and wert == "Done":
    data["done_at"] = ts

# S2 — done_at löschen wenn status von Done weg wechselt
if feld == "status" and wert != "Done":
    data["done_at"] = None

# blocked_reason löschen wenn status != Blocked
if feld == "status" and wert != "Blocked":
    if "blocked_reason" in data:
        data["blocked_reason"] = None

# updated_at nachziehen
data["updated_at"] = ts

# Normalisieren (datetime-Objekte aus YAML → Strings)
data = normalize(data)

with open(tmp_out, "w") as f:
    yaml.dump(data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)
PYEOF

  mv "$tmp_file" "$item_file"

  # Trap aufheben (Erfolg)
  trap - EXIT

  echo "$id"
}

# ---------------------------------------------------------------------------
# Verb: show
# ---------------------------------------------------------------------------
cmd_show() {
  local id="$1"
  [[ -n "$id" ]] || die "show: ID fehlt"

  require_board

  local item_file
  item_file="$(find_item_file "$id")"
  [[ -n "$item_file" ]] || die "show: ID '${id}' nicht gefunden"

  yaml_to_json "$item_file"
}

# ---------------------------------------------------------------------------
# Verb: list
# ---------------------------------------------------------------------------
cmd_list() {
  local filter_type="" filter_status="" filter_parent=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)   shift; filter_type="$1"   ;;
      --status) shift; filter_status="$1" ;;
      --parent) shift; filter_parent="$1" ;;
      *) die "list: unbekannte Option '$1'" ;;
    esac
    shift
  done

  require_board

  # Alle Dateien einsammeln
  local all_files=()
  if [[ -z "$filter_type" || "$filter_type" == "feature" ]]; then
    if [[ -d "$FEATURES_DIR" ]]; then
      while IFS= read -r -d '' f; do
        all_files+=("$f")
      done < <(find "$FEATURES_DIR" -name "F-*.yaml" -print0 2>/dev/null | sort -z)
    fi
  fi
  if [[ -z "$filter_type" || "$filter_type" == "story" ]]; then
    if [[ -d "$STORIES_DIR" ]]; then
      while IFS= read -r -d '' f; do
        all_files+=("$f")
      done < <(find "$STORIES_DIR" -name "S-*.yaml" -not -path "*/archive/*" -print0 2>/dev/null | sort -z)
    fi
  fi

  # JSON-Liste aufbauen + filtern + sortieren via Python
  python3 - "$filter_type" "$filter_status" "$filter_parent" "${all_files[@]+"${all_files[@]}"}" <<'PYEOF'
import sys, yaml, json, datetime, re

filter_type   = sys.argv[1]
filter_status = sys.argv[2]
filter_parent = sys.argv[3]
files         = sys.argv[4:]

PRIORITY_ORDER = {"P0": 0, "P1": 1, "P2": 2, "P3": 3}

def normalize(val):
    if isinstance(val, datetime.datetime):
        if val.tzinfo is not None:
            import datetime as dt
            val = val.astimezone(dt.timezone.utc)
        return val.strftime("%Y-%m-%dT%H:%M:%SZ")
    if isinstance(val, datetime.date):
        return val.isoformat() + "T00:00:00Z"
    if isinstance(val, dict):
        return {k: normalize(v) for k, v in val.items()}
    if isinstance(val, list):
        return [normalize(i) for i in val]
    return val

def id_sort_key(id_str):
    """Numerischer Sort für F-### und S-### IDs."""
    m = re.match(r'^[FS]-(\d+)$', str(id_str or ""))
    return int(m.group(1)) if m else 9999999

items = []
for f in files:
    try:
        with open(f) as fh:
            data = yaml.safe_load(fh) or {}
    except Exception:
        continue

    item_id  = str(data.get("id", "")).strip()
    item_type = "feature" if item_id.startswith("F-") else "story"

    # Filter: type
    if filter_type and item_type != filter_type:
        continue

    # Filter: status
    if filter_status:
        if data.get("status") != filter_status:
            continue

    # Filter: parent (nur sinnvoll für Stories)
    if filter_parent:
        if data.get("parent") != filter_parent:
            continue

    data = normalize(data)
    items.append(data)

# Sortierung: priority (P0 < P1 < P2 < P3), dann id aufsteigend
items.sort(key=lambda d: (
    PRIORITY_ORDER.get(str(d.get("priority", "P3")), 9),
    id_sort_key(d.get("id"))
))

print(json.dumps(items, ensure_ascii=False))
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: next — Queue-Logik (AC6, board-cli-Spec V6 + board-subsystem §7)
#
# Algorithmus:
#   1. Kandidaten = alle Stories mit status == "To Do" (Verworfen nie enthalten, AC4)
#   2. Filter: alle depends-Stories terminal (status ∈ {Done, Verworfen}, AC3; offene → überspringen)
#   3. Sortierung: Story-priority (P0<P1<P2<P3) → Parent-Feature-priority → id (aufsteigend)
#   4. Ergebnis = erstes Element als JSON (id, spec, implements, parent, priority, labels)
#      Keine bereite Story → leere Ausgabe, Exit 0
# ---------------------------------------------------------------------------
cmd_next() {
  # KEIN require_board — next ist ein lesendes Verb; fehlendes Board/Verzeichnis → leere
  # Ausgabe + Exit 0 (board-cli-Spec AC6 Edge-Case; coder/L15).

  # Alle Dateien einsammeln (archive/ ausgeschlossen)
  local story_files=()
  if [[ -d "$STORIES_DIR" ]]; then
    while IFS= read -r -d '' f; do
      story_files+=("$f")
    done < <(find "$STORIES_DIR" -name "S-*.yaml" -not -path "*/archive/*" -print0 2>/dev/null | sort -z)
  fi

  local feature_files=()
  if [[ -d "$FEATURES_DIR" ]]; then
    while IFS= read -r -d '' f; do
      feature_files+=("$f")
    done < <(find "$FEATURES_DIR" -name "F-*.yaml" -print0 2>/dev/null | sort -z)
  fi

  # Queue-Logik via Python (deterministisch, kein LLM)
  python3 - "${#story_files[@]}" "${story_files[@]+"${story_files[@]}"}" \
             "${#feature_files[@]}" "${feature_files[@]+"${feature_files[@]}"}" <<'PYEOF'
import sys, yaml, json, datetime, re

# Argumente: <n_stories> <story_file...> <n_features> <feature_file...>
args = sys.argv[1:]
n_stories  = int(args[0])
story_files  = args[1 : 1 + n_stories]
rest         = args[1 + n_stories:]
n_features   = int(rest[0])
feature_files = rest[1 : 1 + n_features]

PRIORITY_ORDER = {"P0": 0, "P1": 1, "P2": 2, "P3": 3}
ID_NUM = re.compile(r'^[FS]-(\d+)$')

def load_yaml(path):
    try:
        with open(path) as f:
            return yaml.safe_load(f) or {}
    except Exception:
        return {}

def normalize(val):
    """YAML-Typen → JSON-serialisierbar."""
    if isinstance(val, datetime.datetime):
        if val.tzinfo is not None:
            import datetime as dt
            val = val.astimezone(dt.timezone.utc)
        return val.strftime("%Y-%m-%dT%H:%M:%SZ")
    if isinstance(val, datetime.date):
        return val.isoformat()
    if isinstance(val, dict):
        return {k: normalize(v) for k, v in val.items()}
    if isinstance(val, list):
        return [normalize(i) for i in val]
    return val

def id_num(id_str):
    m = ID_NUM.match(str(id_str or ""))
    return int(m.group(1)) if m else 999999

# --- Alle Stories laden ---
stories = {}  # id -> data
for path in story_files:
    data = load_yaml(path)
    sid = str(data.get("id", "")).strip()
    if sid:
        stories[sid] = data

# --- Alle Features laden (für Tie-Break-Priority) ---
features = {}  # id -> data
for path in feature_files:
    data = load_yaml(path)
    fid = str(data.get("id", "")).strip()
    if fid:
        features[fid] = data

# --- Schritt 1: Kandidaten = To-Do-Stories ---
# Nur "To Do" ist Kandidat; "Verworfen" (terminal, Won't-Do) wird NIE aufgegriffen (AC4).
candidates = [
    (sid, data)
    for sid, data in stories.items()
    if str(data.get("status", "")).strip() == "To Do"
]

# --- Schritt 2: Filter — alle depends terminal ({Done, Verworfen}) ---
ready = []
for sid, data in candidates:
    deps = data.get("depends")
    if deps is None:
        deps = []
    elif not isinstance(deps, list):
        deps = [deps]
    deps = [str(d).strip() for d in deps if str(d).strip()]

    # Depends-Gate: terminale Menge = {Done, Verworfen} erfuellt das Gate
    # (Verworfen = terminal, s. story-status-verworfen AC3). Ein Dependent wird
    # dadurch nicht dauerhaft blockiert, wenn seine Vorbedingung verworfen wurde.
    all_done = True
    for dep_id in deps:
        dep_data = stories.get(dep_id, {})
        if str(dep_data.get("status", "")).strip() not in ("Done", "Verworfen"):
            all_done = False
            break

    if all_done:
        ready.append((sid, data))

if not ready:
    # Keine bereite Story — leere Ausgabe, Exit 0
    sys.exit(0)

# --- Schritt 3: Sortierung ---
def sort_key(item):
    sid, data = item
    story_prio   = PRIORITY_ORDER.get(str(data.get("priority", "P3")), 9)
    parent_id    = str(data.get("parent", "")).strip()
    parent_data  = features.get(parent_id, {})
    feature_prio = PRIORITY_ORDER.get(str(parent_data.get("priority", "P3")), 9)
    return (story_prio, feature_prio, id_num(sid))

ready.sort(key=sort_key)

# --- Schritt 4: Erste Story als JSON ausgeben ---
best_id, best_data = ready[0]
best_data = normalize(best_data)

output = {
    "id":         best_data.get("id"),
    "spec":       best_data.get("spec"),
    "implements": best_data.get("implements"),
    "parent":     best_data.get("parent"),
    "priority":   best_data.get("priority"),
    "labels":     best_data.get("labels"),
    # Zusatzfelder für /flow (title, status als Kontext)
    "title":      best_data.get("title"),
    "status":     best_data.get("status"),
    "depends":    best_data.get("depends"),
}

print(json.dumps(output, ensure_ascii=False))
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: rollup — AC7
#
# `board rollup <F-###>` oder `board rollup --all`
#
# Berechnet für das/die Feature(s) die abgeleiteten Felder:
#   stories[]  — sortierte Liste der Kind-Story-IDs
#   progress   — z.B. "2/3 done · 1 in progress"
# Schreibt NUR diese abgeleiteten Felder + updated_at atomar zurück.
# ---------------------------------------------------------------------------
cmd_rollup() {
  [[ $# -ge 1 ]] || die "rollup: Verwendung: board rollup <F-###> | --all"

  local target="$1"

  require_board

  if [[ "$target" == "--all" ]]; then
    # Alle Features rollup'en
    local had_error=0
    local feat_file
    while IFS= read -r feat_file; do
      [[ -n "$feat_file" ]] || continue
      _rollup_one "$feat_file" || had_error=1
    done < <(all_features)
    return $had_error
  else
    # Einzelnes Feature
    [[ "$target" =~ ^F-[0-9]{3,}$ ]] || \
      die "rollup: ID muss F-### sein oder --all, war '${target}'"
    local feat_file
    feat_file="$(find_item_file "$target")"
    [[ -n "$feat_file" ]] || die "rollup: Feature '${target}' nicht gefunden"
    _rollup_one "$feat_file"
  fi
}

# Interne Hilfsfunktion: berechnet + schreibt Rollup für eine Feature-Datei.
_rollup_one() {
  local feat_file="$1"

  # Feature-ID ermitteln
  local feat_id
  feat_id="$(yaml_field "$feat_file" id)"
  [[ -n "$feat_id" ]] || die "rollup: Feature-Datei '${feat_file}' hat keine id"

  local ts
  ts="$(now_ts)"

  # Alle Kind-Stories einsammeln (archive/ ausgeschlossen)
  local story_files=()
  if [[ -d "$STORIES_DIR" ]]; then
    while IFS= read -r -d '' f; do
      story_files+=("$f")
    done < <(find "$STORIES_DIR" -name "S-*.yaml" -not -path "*/archive/*" -print0 2>/dev/null | sort -z)
  fi

  # Atomar: temp-Datei in gleichem Verzeichnis wie Feature-Datei
  local dir_abs
  dir_abs="$(cd "$(dirname "$feat_file")" && pwd)"
  local tmp_file
  tmp_file="$(mktemp "${dir_abs}/$(basename "$feat_file").XXXXXX")"

  trap "rm -f \"$tmp_file\"" EXIT

  # Python: berechnet stories[] + progress, schreibt nur abgeleitete Felder
  python3 - "$feat_file" "$tmp_file" "$feat_id" "$ts" \
            "${#story_files[@]}" "${story_files[@]+"${story_files[@]}"}" <<'PYEOF'
import sys, yaml, json, datetime, re

feat_file   = sys.argv[1]
tmp_out     = sys.argv[2]
feat_id     = sys.argv[3]
ts          = sys.argv[4]
n_stories   = int(sys.argv[5])
story_files = sys.argv[6 : 6 + n_stories]

ID_NUM = re.compile(r'^S-(\d+)$')

def id_num(sid):
    m = ID_NUM.match(str(sid or ""))
    return int(m.group(1)) if m else 999999

def normalize_ts(val):
    """YAML datetime → ISO-8601-UTC-String."""
    if isinstance(val, datetime.datetime):
        if val.tzinfo is not None:
            import datetime as dt
            utc = val.astimezone(dt.timezone.utc)
        else:
            utc = val
        return utc.strftime("%Y-%m-%dT%H:%M:%SZ")
    if isinstance(val, datetime.date):
        return val.isoformat() + "T00:00:00Z"
    return val

def normalize_all(val):
    """Rekursive Normalisierung (YAML-Typen → JSON-serialisierbar)."""
    if isinstance(val, datetime.datetime) or isinstance(val, datetime.date):
        return normalize_ts(val)
    if isinstance(val, dict):
        return {k: normalize_all(v) for k, v in val.items()}
    if isinstance(val, list):
        return [normalize_all(i) for i in val]
    return val

# --- Feature-YAML laden ---
with open(feat_file) as f:
    feat_data = yaml.safe_load(f) or {}

# --- Kind-Stories finden + Status einlesen ---
status_counter = {}  # status -> count
child_ids = []

for spath in story_files:
    try:
        with open(spath) as f:
            sdata = yaml.safe_load(f) or {}
    except Exception:
        continue
    parent = str(sdata.get("parent", "")).strip()
    if parent != feat_id:
        continue
    sid = str(sdata.get("id", "")).strip()
    if not sid:
        continue
    sstatus = str(sdata.get("status", "")).strip()
    child_ids.append(sid)
    status_counter[sstatus] = status_counter.get(sstatus, 0) + 1

# Sortiert nach ID-Nummer
child_ids.sort(key=id_num)

# --- progress berechnen ---
total       = len(child_ids)
done_count  = status_counter.get("Done", 0)
ip_count    = status_counter.get("In Progress", 0)
review_count = status_counter.get("In Review", 0)
blocked_count = status_counter.get("Blocked", 0)
verworfen_count = status_counter.get("Verworfen", 0)
todo_count  = status_counter.get("To Do", 0)

# Format: "<done>/<total> done [· <n> in progress] [· <n> in review] [· <n> blocked] [· <n> verworfen]"
# done/total zaehlt NUR erfolgreich abgeschlossene (Done); Verworfen wird separat
# als Suffix ausgewiesen (nur wenn N>0) und nicht in done gemischt (AC5).
# Der "<done>/<total> done"-Praefix bleibt formatstabil (ROLLUP-STALE-Praefix-Check).
parts = [f"{done_count}/{total} done"]
if ip_count > 0:
    parts.append(f"{ip_count} in progress")
if review_count > 0:
    parts.append(f"{review_count} in review")
if blocked_count > 0:
    parts.append(f"{blocked_count} blocked")
if verworfen_count > 0:
    parts.append(f"{verworfen_count} verworfen")

progress_str = " · ".join(parts) if total > 0 else "0/0 done"

# Feature-Vollstaendigkeit (terminale Menge {Done, Verworfen}) ist erreicht, wenn
# done + verworfen == total. Der progress-String ist das Signal, aus dem der Owner
# (bzw. der dev-gui-Aggregator) den Feature-Rollup-Status Done ableitet (board-subsystem §5);
# rollup schreibt selbst keinen Feature-Status. Der done/total-Zaehler behaelt die Bedeutung
# "erfolgreich abgeschlossen / gesamt"; Verworfen zaehlt terminal, aber nie als erfolgreich (AC5).
#
# Bereichs-Feature-Permanenz (docs/specs/board-areas.md AC3): weil rollup NIE einen
# Feature-status schreibt — auch fuer Features mit gesetztem `area` (Bereichs-Feature)
# nicht — bleibt ein Bereichs-Feature dauerhaft (nie automatisch Done/Archived), selbst
# wenn alle Kind-Storys terminal sind. progress wird trotzdem weiter berechnet (s.o.).

# --- Nur abgeleitete Felder + updated_at überschreiben ---
feat_data = normalize_all(feat_data)
feat_data["stories"]    = child_ids if child_ids else None
feat_data["progress"]   = progress_str
feat_data["updated_at"] = ts

with open(tmp_out, "w") as f:
    yaml.dump(feat_data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)
PYEOF

  mv "$tmp_file" "$feat_file"

  trap - EXIT

  echo "$feat_id"
}

# ---------------------------------------------------------------------------
# Verb: lint — delegiert an scripts/board-lint.sh
# ---------------------------------------------------------------------------
cmd_lint() {
  local lint_script
  lint_script="$(cd "$(dirname "$0")" && pwd)/board-lint.sh"
  if [[ ! -x "$lint_script" ]]; then
    die "lint: ${lint_script} nicht gefunden oder nicht ausführbar"
  fi
  exec "$lint_script" "${1:-${BOARD_DIR}}"
}

# ---------------------------------------------------------------------------
# Verb: export-github — delegiert an scripts/board-github-export (AC11 / #129)
#
# Optionen werden 1:1 durchgereicht; board-github-export --help zeigt Details.
# ---------------------------------------------------------------------------
cmd_export_github() {
  local export_script
  export_script="$(cd "$(dirname "$0")" && pwd)/board-github-export"

  if [[ ! -x "$export_script" ]]; then
    die "export-github: ${export_script} nicht gefunden oder nicht ausführbar"
  fi

  # BOARD_DIR aus der aktuellen Shell-Umgebung weitergeben (falls gesetzt)
  if [[ -n "${BOARD_DIR:-}" ]]; then
    exec "$export_script" --board-dir "$BOARD_DIR" "$@"
  else
    exec "$export_script" "$@"
  fi
}

# ---------------------------------------------------------------------------
# Verb: area list — AC1 (docs/specs/board-area-ops.md)
#
# Gibt board/areas.yaml als sortiertes JSON-Array aus (Felder id, titel,
# beschreibung, reihenfolge). Fehlt areas.yaml (oder ist sie leer/kein
# Mapping) → leeres Array, Exit 0. Lesend, token-frei/deterministisch —
# kein require_board (areas.yaml ist optional, board-areas AC1/E2).
# ---------------------------------------------------------------------------
cmd_area_list() {
  local areas_file="${BOARD_DIR}/areas.yaml"

  python3 - "$areas_file" <<'PYEOF'
import sys, yaml, json

areas_file = sys.argv[1]

try:
    with open(areas_file, encoding="utf-8") as f:
        data = yaml.safe_load(f)
except FileNotFoundError:
    data = None
except Exception:
    # Malformte areas.yaml wird von `board lint` (AREA-FIELD) diagnostiziert;
    # `area list` bleibt tolerant und liefert im Zweifel ein leeres Array.
    data = None

if not isinstance(data, list):
    print("[]")
    sys.exit(0)

items = []
for entry in data:
    if not isinstance(entry, dict):
        continue
    items.append({
        "id":           entry.get("id"),
        "titel":        entry.get("titel"),
        "beschreibung": entry.get("beschreibung"),
        "reihenfolge":  entry.get("reihenfolge"),
    })

def sort_key(item):
    r = item.get("reihenfolge")
    return r if (isinstance(r, int) and not isinstance(r, bool)) else 10**9

items.sort(key=sort_key)

print(json.dumps(items, ensure_ascii=False))
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: area merge — AC2/AC5 (docs/specs/board-area-ops.md)
#
# `board area merge <a> <b> <ziel>` legt Bereich <a>/<b> unter <ziel> zusammen:
#   - areas.yaml: <a>/<b>-Eintraege entfernen (sofern != <ziel>), <ziel>
#     behalten oder neu anlegen (Titel/Beschreibung von <a>, sonst <b>;
#     naechste reihenfolge — Spec-Praezisierung, s. Edge-Cases in der Spec).
#   - Mechanisches Umschreiben aller area-Etiketten (Feature-`area`,
#     Spec-`area`-Frontmatter, Ideen-Inbox-`- area:`-Eintraege) von <a>/<b>
#     auf <ziel>.
#   - Keine Dateiverschiebung, keine Spec-ID-Aenderung.
#
# Gueltigkeits-/Idempotenz-Regel (Spec-Praezisierung, s. Edge-Cases):
#   "Unbekannter Bereich" (Fehler, kein Schreiben, Exit != 0) nur wenn WEDER
#   <a> NOCH <b> NOCH <ziel> als Eintrag in areas.yaml existiert. Ist
#   mindestens einer bekannt, laeuft der Merge durch — bereits fehlende
#   <a>/<b>-Eintraege gelten als "nichts zu entfernen" (kein Fehler). Das
#   macht einen zweiten, identischen Aufruf idempotent (AC2).
#
# Atomaritaet (AC5): saemtliche Validierung + Aenderungsberechnung laeuft VOR
# jedem Schreibzugriff (python err()-Pfad beendet ohne jede Datei beruehrt zu
# haben); jede tatsaechlich veraenderte Datei wird einzeln atomar geschrieben
# (tmp im selben Verzeichnis + os.replace).
# ---------------------------------------------------------------------------
cmd_area_merge() {
  [[ $# -eq 3 ]] || die "area merge: Verwendung: board area merge <a> <b> <ziel>"

  local area_a="$1" area_b="$2" area_ziel="$3"
  [[ -n "$area_a" && -n "$area_b" && -n "$area_ziel" ]] || \
    die "area merge: <a>/<b>/<ziel> duerfen nicht leer sein"

  require_board

  local repo_root
  repo_root="$(cd "${BOARD_DIR}/.." && pwd)"

  local ts
  ts="$(now_ts)"

  python3 - "$BOARD_DIR" "$repo_root" "$area_a" "$area_b" "$area_ziel" "$ts" <<'PYEOF'
import sys, os, re, json, yaml, tempfile

board_dir  = sys.argv[1]
repo_root  = sys.argv[2]
area_a     = sys.argv[3]
area_b     = sys.argv[4]
area_ziel  = sys.argv[5]
ts         = sys.argv[6]

areas_path   = os.path.join(board_dir, "areas.yaml")
features_dir = os.path.join(board_dir, "features")
specs_dir    = os.path.join(repo_root, "docs", "specs")
ideas_path   = os.path.join(repo_root, "docs", "ideas-inbox.md")


def err(msg):
    print(f"FEHLER: area merge: {msg}", file=sys.stderr)
    sys.exit(1)


# --- areas.yaml laden (einzige Quelle gueltiger Bereichs-ids) ---
areas_list = []
if os.path.isfile(areas_path):
    try:
        with open(areas_path, encoding="utf-8") as f:
            loaded = yaml.safe_load(f)
    except Exception as e:
        err(f"areas.yaml nicht lesbar/parsebar ({e}) — 'board lint' zur Diagnose nutzen")
        loaded = None  # unreachable, err() beendet den Prozess
    if loaded is not None:
        if not isinstance(loaded, list):
            err("areas.yaml ist keine YAML-Liste (malformt) — 'board lint' zur Diagnose nutzen")
        areas_list = loaded

entries_by_id = {}
for entry in areas_list:
    if isinstance(entry, dict) and entry.get("id") is not None:
        entries_by_id[str(entry["id"]).strip()] = entry

known_ids = set(entries_by_id.keys())

# --- E1: unbekannter Bereich ---
if area_ziel not in known_ids and area_a not in known_ids and area_b not in known_ids:
    err(f"weder '{area_a}' noch '{area_b}' noch '{area_ziel}' ist in areas.yaml bekannt")

# --- <ziel>-Eintrag bestimmen/anlegen ---
ziel_new = area_ziel not in known_ids
new_ziel_entry = None
if ziel_new:
    # AC5-Garantie: eine NEU angelegte <ziel>-id muss dem Kebab-Case-Pattern
    # aus board/areas.schema.json entsprechen (siehe coder/L31) — sonst
    # entsteht ein schema-invalider Datensatz, den `board lint` erst beim
    # naechsten Lauf erkennt statt beim Schreiben selbst.
    ID_PATTERN = re.compile(r"^[a-z][a-z0-9]*(-[a-z0-9]+)*$")
    if not ID_PATTERN.match(area_ziel):
        err(f"'{area_ziel}' ist keine gueltige Bereichs-id (erwartet kebab-case: ^[a-z][a-z0-9]*(-[a-z0-9]+)*$)")

    source_entry = entries_by_id.get(area_a) or entries_by_id.get(area_b)

    def is_int_reihenfolge(v):
        return isinstance(v, int) and not isinstance(v, bool)

    ordnungen = [e.get("reihenfolge") for e in areas_list if isinstance(e, dict)]
    ordnungen = [o for o in ordnungen if is_int_reihenfolge(o)]
    next_reihenfolge = (max(ordnungen) + 1) if ordnungen else 1

    new_ziel_entry = {
        "id":           area_ziel,
        "titel":        source_entry.get("titel"),
        "beschreibung": source_entry.get("beschreibung"),
        "reihenfolge":  next_reihenfolge,
    }

# --- alte Labels, die auf <ziel> umgeschrieben werden ---
old_labels = {area_a, area_b} - {area_ziel}

# --- neue areas.yaml-Liste berechnen ---
new_areas_list = [
    e for e in areas_list
    if not (isinstance(e, dict) and str(e.get("id", "")).strip() in old_labels)
]
if ziel_new:
    new_areas_list.append(new_ziel_entry)

areas_changed = (new_areas_list != areas_list)

# --- Feature-Dateien: area-Etikett umschreiben ---
feature_writes = []
if os.path.isdir(features_dir):
    for fname in sorted(os.listdir(features_dir)):
        if not fname.endswith(".yaml"):
            continue
        fpath = os.path.join(features_dir, fname)
        try:
            with open(fpath, encoding="utf-8") as f:
                fdata = yaml.safe_load(f) or {}
        except Exception as e:
            err(f"Feature-Datei {fpath} nicht lesbar ({e})")
        area_val = fdata.get("area")
        if area_val is not None and str(area_val).strip() in old_labels:
            fdata["area"] = area_ziel
            fdata["updated_at"] = ts
            new_text = yaml.dump(fdata, allow_unicode=True, default_flow_style=False, sort_keys=False)
            feature_writes.append((fpath, new_text))

# --- Spec-Frontmatter: area-Etikett umschreiben ---
FRONTMATTER_BLOCK = re.compile(r"^(---\s*\n)(.*?)(\n---\s*\n)", re.DOTALL)
AREA_LINE = re.compile(r"^(area:)\s*(.+?)\s*$", re.MULTILINE)

spec_writes = []
if os.path.isdir(specs_dir):
    for fname in sorted(os.listdir(specs_dir)):
        if not fname.endswith(".md"):
            continue
        spath = os.path.join(specs_dir, fname)
        try:
            with open(spath, encoding="utf-8", errors="replace") as f:
                content = f.read()
        except Exception as e:
            err(f"Spec-Datei {spath} nicht lesbar ({e})")
        fm_match = FRONTMATTER_BLOCK.match(content)
        if not fm_match:
            continue
        fm_body = fm_match.group(2)
        area_match = AREA_LINE.search(fm_body)
        if not area_match:
            continue
        area_val = area_match.group(2).split("#", 1)[0].strip()
        if area_val not in old_labels:
            continue
        new_fm_body = AREA_LINE.sub(lambda m: f"{m.group(1)} {area_ziel}", fm_body, count=1)
        new_content = content[:fm_match.start(2)] + new_fm_body + content[fm_match.end(2):]
        spec_writes.append((spath, new_content))

# --- Ideen-Inbox: "- area: <bereich>"-Eintraege umschreiben ---
IDEA_AREA_LINE = re.compile(r"^(- area:)\s*(.+?)\s*$", re.MULTILINE)
ideas_write = None
if os.path.isfile(ideas_path):
    try:
        with open(ideas_path, encoding="utf-8", errors="replace") as f:
            ideas_content = f.read()
    except Exception as e:
        err(f"Ideen-Inbox {ideas_path} nicht lesbar ({e})")

    def repl(m):
        val = m.group(2).split("#", 1)[0].strip()
        if val in old_labels:
            return f"{m.group(1)} {area_ziel}"
        return m.group(0)

    new_ideas_content = IDEA_AREA_LINE.sub(repl, ideas_content)
    if new_ideas_content != ideas_content:
        ideas_write = new_ideas_content

# --- Ab hier: nur noch Schreiben (Validierung/Berechnung ist abgeschlossen) ---

def atomic_write(path, text):
    d = os.path.dirname(os.path.abspath(path))
    fd, tmp = tempfile.mkstemp(dir=d, prefix=os.path.basename(path) + ".")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(text)
        os.replace(tmp, path)
    except Exception:
        try:
            os.remove(tmp)
        except OSError:
            pass
        raise

if areas_changed:
    atomic_write(areas_path, yaml.dump(new_areas_list, allow_unicode=True, default_flow_style=False, sort_keys=False))

for fpath, text in feature_writes:
    atomic_write(fpath, text)

for spath, text in spec_writes:
    atomic_write(spath, text)

if ideas_write is not None:
    atomic_write(ideas_path, ideas_write)

print(area_ziel)
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: area split — AC4/AC5 (docs/specs/board-area-ops.md)
#
# `board area split <a> <a1> <a2>` ist ASSISTIERT (im Unterschied zu merge,
# das vollautomatisch ist): es listet alle Artefakte von <a> —
#   - Specs mit `area: <a>`-Frontmatter
#   - Features mit `area: <a>` (+ ihre Storys, informativ)
#   - Ideen-Inbox-Eintraege mit `- area: <a>`
# — mit einem Ziel-Vorschlag (<a1>|<a2>) + Konfidenz (token-freie,
# deterministische Wort-Ueberlappungs-Heuristik der Artefakt-Bezeichner gegen
# id/titel/beschreibung der beiden Ziel-Bereiche). Eindeutige Faelle werden
# SOFORT umgeschrieben (Etikett); mehrdeutige (Punktegleichstand, inkl. 0:0)
# landen als maschinenlesbarer Fragenkatalog ({stage,id,frage,quelle,
# optionen}, board/fragenkatalog.schema.json, stage="split").
#
# Spec-Praezisierung (bindender Kontext-Abschnitt von board-area-ops.md):
# NUR Feature-`area`, Spec-`area`-Frontmatter und Ideen-Inbox-`- area:` sind
# schreibbare Bereichs-Etiketten (identisch zu merge, AC2). Eine Story TRAEGT
# KEIN eigenes `area`-Feld — ihre Bereichszugehoerigkeit haengt an ihrem
# Eltern-Feature. Storys erscheinen im Report daher NUR informativ (mit dem
# Ziel/Konfidenz-Ergebnis IHRES Eltern-Features); sie werden nicht separat
# befragt oder geschrieben (kein Story-Reparenting — Kern-CRUD ist laut Spec
# ein Nicht-Ziel dieser Operation).
#
# E2: neue Ziel-Bereiche <a1>/<a2> werden — sofern noch unbekannt — SOFORT in
# areas.yaml angelegt (Platzhalter-`beschreibung` + naechste `reihenfolge`),
# damit kein zugeordnetes Artefakt je auf einen fehlenden Bereich zeigt
# (kein AREA-UNKNOWN-Zwischenzustand). Der Quell-Bereich <a> wird nur
# entfernt, wenn ALLE schreibbaren Artefakte zugeordnet sind (Fragenkatalog
# leer) UND <a> nicht selbst als <a1>/<a2> weiterverwendet wird.
#
# AC5: saemtliche Validierung + Heuristik laeuft VOR jedem Schreibzugriff im
# Python-Prozess (err() beendet ohne Datei beruehrt zu haben); jede
# tatsaechlich veraenderte Datei wird einzeln atomar geschrieben. <a1>==<a2>
# ist eine ungueltige Eingabe (kein sinnvoller Split) -> Fehler, kein
# Schreiben, Exit != 0. Unbekannter Quell-Bereich <a> -> E1, kein Schreiben,
# Exit != 0 (Ziel-Bereiche duerfen dagegen neu sein, E2).
# ---------------------------------------------------------------------------
cmd_area_split() {
  [[ $# -eq 3 ]] || die "area split: Verwendung: board area split <a> <a1> <a2>"

  local area_a="$1" area_a1="$2" area_a2="$3"
  [[ -n "$area_a" && -n "$area_a1" && -n "$area_a2" ]] || \
    die "area split: <a>/<a1>/<a2> duerfen nicht leer sein"
  [[ "$area_a1" != "$area_a2" ]] || \
    die "area split: <a1> und <a2> muessen unterschiedlich sein"

  require_board

  local repo_root
  repo_root="$(cd "${BOARD_DIR}/.." && pwd)"

  # Board-Verzeichnis absolut auf DENSELBEN Pfad-Stamm wie repo_root aufloesen
  # (beide via `pwd` im selben Shell-Prozess) — sonst weichen relative
  # BOARD_DIR-Pfade und repo_root bei symlinked /tmp (macOS: /tmp -> /private/tmp)
  # auseinander und os.path.relpath() im Report ergibt Muell (nur kosmetisch,
  # betrifft nicht die Schreib-Pfade selbst, aber die Report-„quelle"-Felder).
  local board_dir_abs
  board_dir_abs="$(cd "$BOARD_DIR" && pwd)"

  local ts
  ts="$(now_ts)"

  python3 - "$board_dir_abs" "$repo_root" "$area_a" "$area_a1" "$area_a2" "$ts" <<'PYEOF'
import sys, os, re, json, yaml, tempfile

board_dir = sys.argv[1]
repo_root = sys.argv[2]
area_a    = sys.argv[3]
area_a1   = sys.argv[4]
area_a2   = sys.argv[5]
ts        = sys.argv[6]

areas_path   = os.path.join(board_dir, "areas.yaml")
features_dir = os.path.join(board_dir, "features")
stories_dir  = os.path.join(board_dir, "stories")
specs_dir    = os.path.join(repo_root, "docs", "specs")
ideas_path   = os.path.join(repo_root, "docs", "ideas-inbox.md")


def err(msg):
    print(f"FEHLER: area split: {msg}", file=sys.stderr)
    sys.exit(1)


def atomic_write(path, text):
    d = os.path.dirname(os.path.abspath(path))
    fd, tmp = tempfile.mkstemp(dir=d, prefix=os.path.basename(path) + ".")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(text)
        os.replace(tmp, path)
    except Exception:
        try:
            os.remove(tmp)
        except OSError:
            pass
        raise


# --- areas.yaml laden (einzige Quelle gueltiger Bereichs-ids) ---
areas_list = []
if os.path.isfile(areas_path):
    try:
        with open(areas_path, encoding="utf-8") as f:
            loaded = yaml.safe_load(f)
    except Exception as e:
        err(f"areas.yaml nicht lesbar/parsebar ({e}) — 'board lint' zur Diagnose nutzen")
        loaded = None  # unreachable, err() beendet den Prozess
    if loaded is not None:
        if not isinstance(loaded, list):
            err("areas.yaml ist keine YAML-Liste (malformt) — 'board lint' zur Diagnose nutzen")
        areas_list = loaded

entries_by_id = {}
for entry in areas_list:
    if isinstance(entry, dict) and entry.get("id") is not None:
        entries_by_id[str(entry["id"]).strip()] = entry

known_ids = set(entries_by_id.keys())

# --- E1: unbekannter Quell-Bereich ---
if area_a not in known_ids:
    err(f"Quell-Bereich '{area_a}' ist nicht in areas.yaml bekannt")

# --- AC5: neue Ziel-ids muessen kebab-case sein (identisch zu merge) ---
ID_PATTERN = re.compile(r"^[a-z][a-z0-9]*(-[a-z0-9]+)*$")
a1_new = area_a1 not in known_ids
a2_new = area_a2 not in known_ids
if a1_new and not ID_PATTERN.match(area_a1):
    err(f"'{area_a1}' ist keine gueltige Bereichs-id (erwartet kebab-case: ^[a-z][a-z0-9]*(-[a-z0-9]+)*$)")
if a2_new and not ID_PATTERN.match(area_a2):
    err(f"'{area_a2}' ist keine gueltige Bereichs-id (erwartet kebab-case: ^[a-z][a-z0-9]*(-[a-z0-9]+)*$)")

# --- Heuristik: token-freie, deterministische Wort-Ueberlappung ---
STOPWORDS = {
    "und", "der", "die", "das", "fuer", "mit", "von", "den", "des", "dem",
    "ein", "eine", "einer", "eines", "im", "in", "auf", "zu", "ist", "als",
    "aus", "sind", "wird", "werden", "sich", "nicht", "oder", "auch", "the",
    "and", "for", "are", "was",
}

WORD_RE = re.compile(r"[a-zA-Z0-9äöüÄÖÜß]+")


def tokens(*texts):
    out = set()
    for text in texts:
        if not text:
            continue
        for w in WORD_RE.findall(str(text).lower()):
            if len(w) >= 3 and w not in STOPWORDS:
                out.add(w)
    return out


def target_tokens(area_id):
    toks = tokens(area_id.replace("-", " "))
    entry = entries_by_id.get(area_id)
    if entry:
        toks |= tokens(entry.get("titel"), entry.get("beschreibung"))
    return toks


tokens_a1 = target_tokens(area_a1)
tokens_a2 = target_tokens(area_a2)


def propose(art_tokens):
    """Liefert (ziel|None, konfidenz) fuer ein Artefakt (token-freie Heuristik)."""
    s1 = len(art_tokens & tokens_a1)
    s2 = len(art_tokens & tokens_a2)
    if s1 > s2 and s1 > 0:
        return area_a1, ("hoch" if s2 == 0 else "mittel")
    if s2 > s1 and s2 > 0:
        return area_a2, ("hoch" if s1 == 0 else "mittel")
    return None, "niedrig"


zuordnungen = []       # Report-Zeilen: {typ,id,quelle,ziel_vorschlag,konfidenz,zugeordnet}
fragenkatalog = []     # {stage,id,frage,quelle,optionen} — board/fragenkatalog.schema.json
spec_writes = []       # (pfad, neuer inhalt)
feature_writes = []    # (pfad, neuer inhalt)
idea_lines_changed = False
idea_lines = None

frage_counter = 0


def next_frage_id():
    global frage_counter
    frage_counter += 1
    return f"split-{frage_counter}"


def add_row(typ, ident, quelle, ziel, konfidenz, zugeordnet):
    zuordnungen.append({
        "typ": typ, "id": ident, "quelle": quelle,
        "ziel_vorschlag": ziel, "konfidenz": konfidenz, "zugeordnet": zugeordnet,
    })


def add_frage(typ, ident, quelle):
    fragenkatalog.append({
        "stage": "split",
        "id": next_frage_id(),
        "frage": f"Zu welchem Bereich gehoert {typ} {ident}?",
        "quelle": quelle,
        "optionen": [area_a1, area_a2],
    })


# --- 1) Specs mit area=<a>-Frontmatter ---
FRONTMATTER_BLOCK = re.compile(r"^(---\s*\n)(.*?)(\n---\s*\n)", re.DOTALL)
AREA_LINE = re.compile(r"^(area:)\s*(.+?)\s*$", re.MULTILINE)

if os.path.isdir(specs_dir):
    for fname in sorted(os.listdir(specs_dir)):
        if not fname.endswith(".md"):
            continue
        spath = os.path.join(specs_dir, fname)
        rel_spath = os.path.relpath(spath, repo_root)
        try:
            with open(spath, encoding="utf-8", errors="replace") as f:
                content = f.read()
        except Exception as e:
            err(f"Spec-Datei {spath} nicht lesbar ({e})")
        fm_match = FRONTMATTER_BLOCK.match(content)
        if not fm_match:
            continue
        fm_body = fm_match.group(2)
        area_match = AREA_LINE.search(fm_body)
        if not area_match:
            continue
        area_val = area_match.group(2).split("#", 1)[0].strip()
        if area_val != area_a:
            continue
        try:
            fm_data = yaml.safe_load(fm_body) or {}
        except Exception:
            fm_data = {}
        if not isinstance(fm_data, dict):
            fm_data = {}
        spec_id = fm_data.get("id") or os.path.splitext(fname)[0]
        spec_title = fm_data.get("title") or ""
        art_tokens = tokens(spec_id, spec_title, os.path.splitext(fname)[0])
        ziel, konf = propose(art_tokens)
        if ziel is not None:
            new_fm_body = AREA_LINE.sub(lambda m: f"{m.group(1)} {ziel}", fm_body, count=1)
            new_content = content[:fm_match.start(2)] + new_fm_body + content[fm_match.end(2):]
            spec_writes.append((spath, new_content))
            add_row("spec", spec_id, rel_spath, ziel, konf, True)
        else:
            add_row("spec", spec_id, rel_spath, None, konf, False)
            add_frage("Spec", spec_id, rel_spath)

# --- 2) Features mit area=<a> (+ ihre Storys, informativ — kein eigenes area-Feld) ---
stories_by_parent = {}
if os.path.isdir(stories_dir):
    for sfname in sorted(os.listdir(stories_dir)):
        if not sfname.endswith(".yaml"):
            continue
        spath = os.path.join(stories_dir, sfname)
        try:
            with open(spath, encoding="utf-8") as f:
                sdata = yaml.safe_load(f) or {}
        except Exception as e:
            err(f"Story-Datei {spath} nicht lesbar ({e})")
        if not isinstance(sdata, dict):
            continue
        parent = sdata.get("parent")
        if parent is None:
            continue
        stories_by_parent.setdefault(str(parent), []).append((spath, sdata))

if os.path.isdir(features_dir):
    for fname in sorted(os.listdir(features_dir)):
        if not fname.endswith(".yaml"):
            continue
        fpath = os.path.join(features_dir, fname)
        rel_fpath = os.path.relpath(fpath, repo_root)
        try:
            with open(fpath, encoding="utf-8") as f:
                fdata = yaml.safe_load(f) or {}
        except Exception as e:
            err(f"Feature-Datei {fpath} nicht lesbar ({e})")
        if not isinstance(fdata, dict):
            continue
        area_val = fdata.get("area")
        if area_val is None or str(area_val).strip() != area_a:
            continue
        feature_id = fdata.get("id") or os.path.splitext(fname)[0]
        art_tokens = tokens(feature_id, fdata.get("title"), fdata.get("goal"))
        ziel, konf = propose(art_tokens)
        if ziel is not None:
            new_fdata = dict(fdata)
            new_fdata["area"] = ziel
            new_fdata["updated_at"] = ts
            new_text = yaml.dump(new_fdata, allow_unicode=True, default_flow_style=False, sort_keys=False)
            feature_writes.append((fpath, new_text))
            add_row("feature", feature_id, rel_fpath, ziel, konf, True)
        else:
            add_row("feature", feature_id, rel_fpath, None, konf, False)
            add_frage("Feature", feature_id, rel_fpath)

        # Storys unter diesem Feature: rein informativ (kein eigenes area-Feld,
        # keine separate Schreib-/Frage-Aktion — sie folgen der Feature-Entscheidung).
        for story_path, sdata in stories_by_parent.get(str(feature_id), []):
            story_id = sdata.get("id") or os.path.splitext(os.path.basename(story_path))[0]
            rel_story = os.path.relpath(story_path, repo_root)
            add_row("story", story_id, rel_story, ziel, konf, ziel is not None)

# --- 3) Ideen-Inbox: "- area: <a>"-Eintraege ---
if os.path.isfile(ideas_path):
    try:
        with open(ideas_path, encoding="utf-8", errors="replace") as f:
            ideas_content = f.read()
    except Exception as e:
        err(f"Ideen-Inbox {ideas_path} nicht lesbar ({e})")
    rel_ideas = os.path.relpath(ideas_path, repo_root)
    idea_lines = ideas_content.split("\n")
    heading_re = re.compile(r"^###\s+(.*)$")
    idea_area_re = re.compile(r"^(- area:)\s*(.+?)\s*$")
    current_heading = None
    for idx, line in enumerate(idea_lines):
        hm = heading_re.match(line)
        if hm:
            current_heading = hm.group(1).strip()
            continue
        am = idea_area_re.match(line)
        if not am:
            continue
        val = am.group(2).split("#", 1)[0].strip()
        if val != area_a:
            continue
        titel = current_heading or "(ohne Titel)"
        art_tokens = tokens(titel)
        ziel, konf = propose(art_tokens)
        if ziel is not None:
            idea_lines[idx] = f"{am.group(1)} {ziel}"
            idea_lines_changed = True
            add_row("idee", titel, rel_ideas, ziel, konf, True)
        else:
            add_row("idee", titel, rel_ideas, None, konf, False)
            add_frage("Idee", titel, rel_ideas)

# --- areas.yaml: neue Ziel-Bereiche anlegen (E2), Quelle ggf. entfernen ---
def is_int_reihenfolge(v):
    return isinstance(v, int) and not isinstance(v, bool)


ordnungen = [e.get("reihenfolge") for e in areas_list if isinstance(e, dict)]
ordnungen = [o for o in ordnungen if is_int_reihenfolge(o)]
next_reihenfolge = (max(ordnungen) + 1) if ordnungen else 1

new_entries = []
if a1_new:
    new_entries.append({
        "id":           area_a1,
        "titel":        area_a1.replace("-", " ").title(),
        "beschreibung": f"TODO: Beschreibung nach Split von '{area_a}' ergaenzen.",
        "reihenfolge":  next_reihenfolge,
    })
    next_reihenfolge += 1
if a2_new:
    new_entries.append({
        "id":           area_a2,
        "titel":        area_a2.replace("-", " ").title(),
        "beschreibung": f"TODO: Beschreibung nach Split von '{area_a}' ergaenzen.",
        "reihenfolge":  next_reihenfolge,
    })
    next_reihenfolge += 1

fully_assigned = len(fragenkatalog) == 0
remove_source = fully_assigned and area_a not in (area_a1, area_a2)

new_areas_list = list(areas_list)
if remove_source:
    new_areas_list = [
        e for e in new_areas_list
        if not (isinstance(e, dict) and str(e.get("id", "")).strip() == area_a)
    ]
new_areas_list = new_areas_list + new_entries

areas_changed = (new_areas_list != areas_list)

# --- Ab hier: nur noch Schreiben (Validierung/Berechnung ist abgeschlossen) ---

if areas_changed:
    atomic_write(areas_path, yaml.dump(new_areas_list, allow_unicode=True, default_flow_style=False, sort_keys=False))

for spath, text in spec_writes:
    atomic_write(spath, text)

for fpath, text in feature_writes:
    atomic_write(fpath, text)

if idea_lines_changed:
    atomic_write(ideas_path, "\n".join(idea_lines))

report = {
    "quell_bereich": area_a,
    "ziel_a1": area_a1,
    "ziel_a2": area_a2,
    "zuordnungen": zuordnungen,
    "fragenkatalog": fragenkatalog,
    "quell_bereich_entfernt": remove_source,
}
print(json.dumps(report, ensure_ascii=False))
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: ready — AC12 (F-008 „Autonome Board-Abarbeitung")
#
# Prüft je To-Do-Story, ob sie „ready" für autonome Abarbeitung ist.
# Ready-Regeln (alle müssen erfüllt sein):
#   R1: status == "To Do"           (andere Stati → n/a, wird übersprungen)
#   R2: spec gesetzt UND Datei existiert UND Frontmatter hat status: active
#   R3: implements nicht leer UND jede AC-Nummer kommt in der Spec vor
#   R4: depends leer ODER alle referenzierten Stories haben status == "Done"
#   R5: blocked_reason leer/null
#
# Ausgabe:
#   READY     S-xxx
#   NOT-READY S-xxx — <Grund(e)>
#   (n/a)     S-xxx  (status != "To Do" — nur ohne --quiet)
#
# Aggregierte NOT-READY-Diagnose (empty-drain-diagnostics AC1/AC2):
#   Nach den Einzelzeilen und vor der Summary ein Aggregat-Block, der die
#   NOT-READY-Stories nach Grund-Kategorie gruppiert (feste Reihenfolge):
#     WAITING spec-not-active (n): S-xxx, … — Specs: docs/specs/a.md, …
#     WAITING spec-missing (n): …
#     WAITING ac-missing (n): …
#     WAITING depends-open (n): …
#     WAITING blocked (n): …
#   Kategorie nur, wenn ≥1 Story betroffen. Eine Story mit mehreren Gründen
#   erscheint in jeder zutreffenden Kategorie. Block entfällt, wenn alle ready
#   oder keine To-Do-Stories vorhanden sind (AC5).
#
# Exit-Code: 0 wenn alle To-Do-Items ready (oder keine To-Do-Items),
#            1 wenn mindestens eine To-Do-Story NOT-READY ist. (unverändert)
# --quiet: unterdrückt n/a-Zeilen; gibt zuletzt eine Summary-Zeile aus.
# ---------------------------------------------------------------------------
cmd_ready() {
  local quiet=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --quiet|-q) quiet=1 ;;
      *) die "ready: unbekannte Option '$1'" ;;
    esac
    shift
  done

  # Lesend: kein require_board — fehlendes Board → Exit 0 (keine To-Do-Items)
  local story_files=()
  if [[ -d "$STORIES_DIR" ]]; then
    while IFS= read -r -d '' f; do
      story_files+=("$f")
    done < <(find "$STORIES_DIR" -name "S-*.yaml" -print0 2>/dev/null | sort -z)
  fi

  # Repo-Wurzel = Verzeichnis über BOARD_DIR (für relative Spec-Pfade).
  # Fallback auf pwd falls BOARD_DIR nicht existiert (fehlendes Board → Exit 0).
  local repo_root
  if [[ -d "$BOARD_DIR" ]]; then
    repo_root="$(cd "${BOARD_DIR}/.." && pwd)"
  else
    repo_root="$(pwd)"
  fi

  python3 - "$STORIES_DIR" "$repo_root" "$quiet" \
            "${#story_files[@]}" "${story_files[@]+"${story_files[@]}"}" <<'PYEOF'
import sys, os, yaml, re

stories_dir  = sys.argv[1]
repo_root    = sys.argv[2]
quiet        = sys.argv[3] == "1"
n_stories    = int(sys.argv[4])
story_files  = sys.argv[5 : 5 + n_stories]

AC_IN_SPEC      = re.compile(r"\bAC(\d+)\b")
FRONTMATTER_RE  = re.compile(r"^---\s*\n(.*?)\n---\s*\n", re.DOTALL)

# --- Alle Stories laden für depends-Status-Lookup ---
stories = {}  # id -> data
for path in story_files:
    try:
        with open(path) as f:
            data = yaml.safe_load(f) or {}
    except Exception:
        data = {}
    sid = str(data.get("id", "")).strip()
    if sid:
        stories[sid] = data

# --- Sortierte IDs für deterministische Ausgabe ---
def id_num(sid):
    m = re.match(r'^S-(\d+)$', str(sid or ""))
    return int(m.group(1)) if m else 999999

sorted_ids = sorted(stories.keys(), key=id_num)

not_ready_count = 0
total_todo = 0

lines = []

# --- Aggregierte NOT-READY-Diagnose (empty-drain-diagnostics AC1/AC2) ---
# Feste, deterministische Kategorien-Reihenfolge. Der Kategorie-Schlüssel ist
# zugleich das stabile Zeilen-Präfix (WAITING <kategorie> …).
CATEGORY_ORDER = [
    "spec-not-active",   # R2: status != active / kein Frontmatter / nicht lesbar
    "spec-missing",      # R2: spec nicht gesetzt / spec-Datei fehlt
    "ac-missing",        # R3: implements leer / AC fehlt in Spec / ungültiger Typ
    "depends-open",      # R4: depends offen / existiert nicht
    "blocked",           # R5: blocked_reason gesetzt
]
cat_stories = {c: [] for c in CATEGORY_ORDER}   # kategorie -> [sid, …] (sortiert durch Iteration)
cat_specs   = {c: [] for c in CATEGORY_ORDER}   # kategorie -> [spec_pfad, …] (für AC2: spec-not-active)

def categorize(reason):
    """Ordnet einen NOT-READY-Grund einer festen Kategorie zu (R2 splittet in zwei)."""
    if reason.startswith("R2:"):
        if "nicht gesetzt" in reason or "spec-Datei fehlt" in reason:
            return "spec-missing"
        return "spec-not-active"
    if reason.startswith("R3:"):
        return "ac-missing"
    if reason.startswith("R4:"):
        return "depends-open"
    if reason.startswith("R5:"):
        return "blocked"
    return None

for sid in sorted_ids:
    data = stories[sid]
    status = str(data.get("status", "")).strip()

    if status != "To Do":
        if not quiet:
            lines.append(f"(n/a)     {sid}")
        continue

    total_todo += 1
    reasons = []

    # R2: spec gesetzt, Datei existiert, Frontmatter status: active
    spec_val = data.get("spec")
    spec_str = str(spec_val).strip() if spec_val is not None else ""
    if not spec_str:
        reasons.append("R2: spec nicht gesetzt")
    else:
        spec_abs = os.path.join(repo_root, spec_str)
        if not os.path.isfile(spec_abs):
            reasons.append(f"R2: spec-Datei fehlt ({spec_str!r})")
        else:
            # Frontmatter status prüfen
            try:
                with open(spec_abs, encoding="utf-8", errors="replace") as f:
                    content = f.read()
                fm_match = FRONTMATTER_RE.match(content)
                if fm_match:
                    try:
                        fm = yaml.safe_load(fm_match.group(1)) or {}
                    except Exception:
                        fm = {}
                    spec_status = str(fm.get("status", "")).strip()
                    if spec_status != "active":
                        reasons.append(f"R2: spec status={spec_status!r} (erwartet 'active')")
                else:
                    # Kein YAML-Frontmatter → als nicht-active werten
                    reasons.append("R2: spec hat kein YAML-Frontmatter (status: active fehlt)")
            except Exception as e:
                reasons.append(f"R2: spec-Datei nicht lesbar ({e})")

    # R3: implements nicht leer UND jede AC-Nummer in der Spec
    impls = data.get("implements")
    if impls is None or (isinstance(impls, list) and len(impls) == 0):
        reasons.append("R3: implements leer")
    elif isinstance(impls, list):
        # Nur prüfen wenn spec existiert und lesbar (sonst bereits R2-Fehler)
        if spec_str and os.path.isfile(os.path.join(repo_root, spec_str)):
            try:
                with open(os.path.join(repo_root, spec_str), encoding="utf-8", errors="replace") as f:
                    spec_content = f.read()
                spec_acs = {"AC" + m.group(1) for m in AC_IN_SPEC.finditer(spec_content)}
                missing_acs = [str(ac).strip() for ac in impls if str(ac).strip() not in spec_acs]
                if missing_acs:
                    reasons.append(f"R3: AC fehlt in Spec: {', '.join(missing_acs)}")
            except Exception:
                pass  # spec-Lesefehler bereits in R2 gemeldet
    else:
        # Skalarer Wert (z.B. implements: AC1 ohne Listenklammern) — ungültiger Typ
        reasons.append("R3: implements hat ungültigen Typ (erwartet Liste)")

    # R4: depends leer ODER alle referenzierten Stories haben status == "Done"
    deps = data.get("depends")
    if deps is not None:
        if not isinstance(deps, list):
            deps = [deps]
        deps = [str(d).strip() for d in deps if str(d).strip()]
        not_done = []
        missing_deps = []
        for dep_id in deps:
            dep_data = stories.get(dep_id)
            if dep_data is None:
                missing_deps.append(dep_id)
            elif str(dep_data.get("status", "")).strip() != "Done":
                not_done.append(f"{dep_id}({dep_data.get('status', '?')})")
        if missing_deps:
            reasons.append(f"R4: depends existiert nicht: {', '.join(missing_deps)}")
        if not_done:
            reasons.append(f"R4: depends nicht Done: {', '.join(not_done)}")

    # R5: blocked_reason leer/null
    blocked = data.get("blocked_reason")
    if blocked is not None and str(blocked).strip():
        reasons.append(f"R5: blocked_reason gesetzt ({str(blocked).strip()!r})")

    if reasons:
        not_ready_count += 1
        lines.append(f"NOT-READY {sid} — {'; '.join(reasons)}")
        # Aggregation: Story in JEDER zutreffenden Kategorie führen (Gründe nicht
        # exklusiv — Doppelnennung über Kategorien ist gewollt, zeigt alle Blocker).
        for reason in reasons:
            cat = categorize(reason)
            if cat is None:
                continue
            if sid not in cat_stories[cat]:
                cat_stories[cat].append(sid)
            # AC2: spec-not-active nennt zusätzlich den betroffenen Spec-Pfad
            if cat == "spec-not-active" and spec_str and spec_str not in cat_specs[cat]:
                cat_specs[cat].append(spec_str)
    else:
        lines.append(f"READY     {sid}")

# Ausgabe
for line in lines:
    print(line)

# --- Aggregierter NOT-READY-Diagnose-Block (empty-drain-diagnostics AC1/AC2) ---
# Nur ausgeben, wenn ≥1 To-Do-Story NOT-READY ist (AC5: bei ausschließlich
# readyen oder keinen To-Do-Stories KEIN Aggregat-Block). Feste Kategorien-
# Reihenfolge; Kategorie nur, wenn ≥1 Story betroffen. Story-IDs deterministisch
# sortiert (Iteration lief über sorted_ids).
if not_ready_count > 0:
    for cat in CATEGORY_ORDER:
        sids = cat_stories[cat]
        if not sids:
            continue
        line = f"WAITING {cat} ({len(sids)}): {', '.join(sids)}"
        if cat == "spec-not-active":
            specs = sorted(set(cat_specs[cat]))
            if specs:
                line += " — Specs: " + ", ".join(specs)
        print(line)

# Summary — immer ausgeben (auch bei --quiet, auch wenn keine To-Do-Items)
if total_todo == 0:
    print(f"Summary: 0 To-Do-Stories — nichts zu prüfen")
else:
    ready_count = total_todo - not_ready_count
    print(f"Summary: {ready_count}/{total_todo} To-Do-Stories ready")

# Exit-Code via sys.exit
sys.exit(1 if not_ready_count > 0 else 0)
PYEOF
}

# ---------------------------------------------------------------------------
# Verb: archive-done-stories — AC3 (board-area-ops)
#
# Verschiebt alle Stories mit status=Done nach board/stories/archive/ (git-erhalten),
# aktualisiert betroffene Feature-Rollups.
# Storys mit anderem Status bleiben unangetastet.
# Idempotent: zweiter Aufruf hat keine Wirkung, leere Ausgabe, Exit 0.
# Ausgabe: Liste archivierter Story-IDs (eine pro Zeile).
# ---------------------------------------------------------------------------
cmd_archive_done_stories() {
  [[ $# -eq 0 ]] || die "archive-done-stories: nimmt keine Argumente entgegen"

  # Lesend: keine require_board() nötig (graceful bei fehlendem Board)
  if [[ ! -d "$STORIES_DIR" ]]; then
    # Kein Stories-Verzeichnis — nichts zu archivieren
    exit 0
  fi

  # Python: Phasen 1-2 — Validierung + Verschieben mit Rollback bei Fehler
  #          Phase 3 — Rollup-Targets sammeln für Bash-Ausführung
  local archive_output
  archive_output=$(python3 - "$BOARD_DIR" "$STORIES_DIR" 2>&1 <<'PYEOF'
import sys, os, subprocess, yaml

board_dir   = sys.argv[1]
stories_dir = sys.argv[2]
repo_root   = os.path.dirname(os.path.abspath(board_dir))

def err(msg):
    print(f"FEHLER: archive-done-stories: {msg}", file=sys.stderr)
    sys.exit(1)

# --- Phase 1: Validierung & Sammlung (OHNE zu verschieben) ---
archive_dir = os.path.join(stories_dir, "archive")

# Archiv-Verzeichnis erstellen falls nötig
if not os.path.isdir(archive_dir):
    try:
        os.makedirs(archive_dir, exist_ok=True)
    except Exception as e:
        err(f"archive-Verzeichnis konnte nicht erstellt werden ({e})")

# Alle Done-Stories sammeln
done_stories = []
try:
    for fname in sorted(os.listdir(stories_dir)):
        if not fname.endswith(".yaml"):
            continue
        if fname.startswith("."):
            continue

        fpath = os.path.join(stories_dir, fname)

        # Archiv-Unterverzeichnis ist ein Verzeichnis — überspringen
        if os.path.isdir(fpath):
            continue

        try:
            with open(fpath, encoding="utf-8") as f:
                data = yaml.safe_load(f) or {}
        except Exception:
            continue

        status = data.get("status")
        if status != "Done":
            continue

        story_id = data.get("id") or os.path.splitext(fname)[0]
        parent = data.get("parent")

        done_stories.append({
            "fname": fname,
            "fpath": fpath,
            "story_id": story_id,
            "parent": parent
        })

except Exception as e:
    err(f"Stories-Verzeichnis konnte nicht gescannt werden ({e})")

# --- Phase 2: Verschiebe alle Done-Stories (mit Rollback bei Fehler) ---
archived_ids = []
affected_parent_ids = set()
moved_files = []  # Zur Rollback im Fehlerfall

try:
    for story in done_stories:
        fpath = story["fpath"]
        fname = story["fname"]
        archive_path = os.path.join(archive_dir, fname)

        # Guard: archive_path darf nicht als Verzeichnis existieren
        if os.path.isdir(archive_path):
            err(f"Archive-Pfad {archive_path} ist ein Verzeichnis, nicht eine Datei")

        # Story bereits archiviert? Idempotent überspringen
        if os.path.exists(archive_path) and not os.path.exists(fpath):
            archived_ids.append(story["story_id"])
            if story["parent"]:
                affected_parent_ids.add(str(story["parent"]).strip())
            continue

        # Story noch in stories/ — verschiebe sie
        if not os.path.exists(fpath):
            continue

        try:
            # git mv — git erklärt das Rename als Rename statt Delete+Add
            subprocess.run(
                ["git", "-C", repo_root, "mv", fpath, archive_path],
                check=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
        except subprocess.CalledProcessError:
            # Fallback auf os.rename falls git fehlschlägt
            try:
                os.rename(fpath, archive_path)
            except Exception as e:
                # Fehler bei Move: Rollback aller bisherigen Moves
                for rolled_back in moved_files:
                    try:
                        orig_path = os.path.join(stories_dir, rolled_back["fname"])
                        arch_path = os.path.join(archive_dir, rolled_back["fname"])
                        if os.path.exists(arch_path):
                            try:
                                subprocess.run(
                                    ["git", "-C", repo_root, "mv", arch_path, orig_path],
                                    check=True,
                                    stdout=subprocess.DEVNULL,
                                    stderr=subprocess.DEVNULL
                                )
                            except subprocess.CalledProcessError:
                                os.rename(arch_path, orig_path)
                    except Exception:
                        pass  # Best-effort Rollback

                err(f"Story-Datei {fname} konnte nicht archiviert werden ({e}). Rollback durchgeführt.")

        moved_files.append({"fname": fname})
        archived_ids.append(story["story_id"])
        if story["parent"]:
            affected_parent_ids.add(str(story["parent"]).strip())

except Exception as e:
    err(f"Fehler während des Archivierens ({e})")

# --- Phase 3: Betroffene Features sammeln (für Rollup im Bash-Teil) ---
features_dir = os.path.join(board_dir, "features")

if os.path.isdir(features_dir):
    for fid in sorted(affected_parent_ids):
        for fname in sorted(os.listdir(features_dir)):
            if not fname.endswith(".yaml"):
                continue
            fpath = os.path.join(features_dir, fname)
            try:
                with open(fpath, encoding="utf-8") as f:
                    fdata = yaml.safe_load(f) or {}
            except Exception:
                continue

            if fdata.get("id") == fid:
                # Feature gefunden — Rollup-Target für Bash-Teil
                print(f"ROLLUP_FEATURE: {fpath}")
                break

# --- Ausgabe: archivierte Story-IDs ---
for sid in archived_ids:
    print(sid)

PYEOF
) || {
    echo "$archive_output" >&2
    return 1
  }

  # Ausgabe splitten: archivierte IDs + Rollup-Targets
  local archived_ids=()
  local rollup_feature_files=()

  while IFS= read -r line; do
    if [[ "$line" =~ ^ROLLUP_FEATURE: ]]; then
      rollup_feature_files+=("${line#ROLLUP_FEATURE: }")
    elif [[ -n "$line" && ! "$line" =~ ^FEHLER ]]; then
      archived_ids+=("$line")
    fi
  done <<<"$archive_output"

  # --- Phase 3: Rollups für betroffene Features ausführen (AC3-Garantie) ---
  for feat_file in "${rollup_feature_files[@]}"; do
    if [[ -f "$feat_file" ]]; then
      _rollup_one "$feat_file" >/dev/null || true
    fi
  done

  # Gebe archivierte Story-IDs aus
  for sid in "${archived_ids[@]}"; do
    echo "$sid"
  done

  return 0
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
[[ $# -ge 1 ]] || usage

VERB="$1"; shift

case "$VERB" in
  feature)
    [[ $# -ge 1 && "$1" == "add" ]] || die "feature: Unterbefehl 'add' erwartet"
    shift
    cmd_feature_add "$@"
    ;;
  story)
    [[ $# -ge 1 && "$1" == "add" ]] || die "story: Unterbefehl 'add' erwartet"
    shift
    cmd_story_add "$@"
    ;;
  set)
    cmd_set "$@"
    ;;
  show)
    [[ $# -ge 1 ]] || die "show: ID fehlt"
    cmd_show "$1"
    ;;
  list)
    cmd_list "$@"
    ;;
  next)
    cmd_next "$@"
    ;;
  rollup)
    cmd_rollup "$@"
    ;;
  lint)
    cmd_lint "$@"
    ;;
  ready)
    cmd_ready "$@"
    ;;
  export-github)
    cmd_export_github "$@"
    ;;
  area)
    [[ $# -ge 1 ]] || die "area: Unterbefehl 'list', 'merge' oder 'split' erwartet"
    AREA_SUB="$1"; shift
    case "$AREA_SUB" in
      list)  cmd_area_list "$@"  ;;
      merge) cmd_area_merge "$@" ;;
      split) cmd_area_split "$@" ;;
      *) die "area: unbekannter Unterbefehl '${AREA_SUB}' (erwartet 'list', 'merge' oder 'split')" ;;
    esac
    ;;
  archive-done-stories)
    cmd_archive_done_stories "$@"
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    die "Unbekanntes Verb '${VERB}'. Nutze 'board --help' für Hilfe."
    ;;
esac
