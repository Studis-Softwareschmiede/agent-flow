# ---------------------------------------------------------------------------
cmd_rollup() {
  die "board rollup: noch nicht implementiert (Item #118)"
}

# ---------------------------------------------------------------------------
# Verb: lint — delegiert an scripts/board-lint.sh
# ---------------------------------------------------------------------------
cmd_lint() {
  local lint_script
  lint_script="$(cd "$(dirname "$0")" && pwd)/board-lint.sh"
  if [[ ! -x "$lint_script" ]]; then
    die "lint: ${lint_script} nicht gefunden oder nicht ausführbar"
  fi
  exec "$lint_script" "${1:-${BOARD_DIR}}"
}

# ---------------------------------------------------------------------------
# Verb: export-github — Stub (AC11, implementiert in [[board-github-export]])
# ---------------------------------------------------------------------------
cmd_export_github() {
  cat >&2 <<'EOF'
board export-github: Verb registriert.
Das eigentliche Migrationsverhalten ist in [[board-github-export]] spezifiziert
und noch nicht implementiert.
EOF
  exit 1
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
[[ $# -ge 1 ]] || usage

VERB="$1"; shift

case "$VERB" in
  feature)
    [[ $# -ge 1 && "$1" == "add" ]] || die "feature: Unterbefehl 'add' erwartet"
    shift
    cmd_feature_add "$@"
    ;;
  story)
    [[ $# -ge 1 && "$1" == "add" ]] || die "story: Unterbefehl 'add' erwartet"
    shift
    cmd_story_add "$@"
    ;;
  set)
    cmd_set "$@"
    ;;
  show)
    [[ $# -ge 1 ]] || die "show: ID fehlt"
    cmd_show "$1"
    ;;
  list)
    cmd_list "$@"
    ;;
  next)
    cmd_next "$@"
    ;;
  rollup)
    cmd_rollup "$@"
    ;;
  lint)
    cmd_lint "$@"
    ;;
  export-github)
    cmd_export_github "$@"
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    die "Unbekanntes Verb '${VERB}'. Nutze 'board --help' für Hilfe."
    ;;
esac
