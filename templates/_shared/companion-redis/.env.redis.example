# .env.redis.example — Vorlage für die Redis-Connection-Variablen
#
# Companion = intern-only. Default-Container ohne Passwort; Apps verbinden
# über das compose-Default-Network per Service-DNS `redis:6379`.
#
# Production / Multi-Tenant-VPS: separater Password-Setup erforderlich
# (siehe README.md „Production"). Dann zusätzlich `REDIS_PASSWORD=...`
# setzen — Passwort NIE eincheken (gehört in `.env.gpg` o.ä.).

REDIS_HOST=redis
REDIS_PORT=6379
