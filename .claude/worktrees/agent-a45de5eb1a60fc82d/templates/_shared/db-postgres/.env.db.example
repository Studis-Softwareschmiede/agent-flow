# .env.db.example — Vorlage für die DB-spezifischen env-Variablen
#
# WICHTIG: Diese Datei ist nur eine Vorlage. Die echte `.env.db` darf
# NIE eingecheckt werden. Sie wird vom Scaffold mit zufälligem Passwort
# initialisiert und gehört in `.env.gpg` (Brewing-Pattern) bzw. ins
# Secret-Management des Ziel-VPS.
#
# Lese-Reihenfolge: docker-compose lädt `.env.db` per `env_file:` in
# die Postgres-/Migrations-Container. NICHT in das default-`.env`
# mixen — das wäre App-Code-Leakage.

POSTGRES_USER=app
# Passwort NICHT commiten — in .env.gpg (Brewing-Pattern) oder VPS-Secret
POSTGRES_PASSWORD=changeme-via-env-gpg
POSTGRES_DB=app
PGDATA=/var/lib/postgresql/data/pgdata
