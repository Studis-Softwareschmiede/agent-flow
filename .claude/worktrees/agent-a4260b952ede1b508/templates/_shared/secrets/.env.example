# .env.example — Vorlage für App-Secrets (committed, KEINE echten Werte).
# Kopiere diese Datei nach .env und trage die echten Werte ein:
#   cp .env.example .env
# Dann verschlüsseln:
#   bash scripts/encrypt-env.sh
# .env ist gitignored (nie committen); .env.gpg wird committiert.

# Beispiel-Variablen — durch projektspezifische Namen ersetzen:
# APP_SECRET=changeme
# DATABASE_URL=postgres://user:password@localhost:5432/mydb
# API_KEY=changeme
